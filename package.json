{
  "name": "pi-subagents-herdr",
  "version": "0.1.1",
  "description": "Herdr-first Pi subagent runtime with Nicobailon agent personas",
  "keywords": [
    "pi-package",
    "pi",
    "subagents",
    "herdr",
    "multi-agent"
  ],
  "license": "MIT",
  "author": "sanai2550",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanai2550/pi-herdr-subagents.git"
  },
  "homepage": "https://github.com/sanai2550/pi-herdr-subagents#readme",
  "bugs": {
    "url": "https://github.com/sanai2550/pi-herdr-subagents/issues"
  },
  "type": "module",
  "files": [
    "src/**/*.ts",
    "agents/**/*.md",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "sync": "node scripts/sync-agents.mjs",
    "check": "node scripts/sync-agents.mjs --check",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/test.ts test/system-prompt-mode.test.ts test/runtime/widget.test.ts test/mux/cmux.test.ts test/live-test-guard.test.ts test/adapter.test.mjs",
    "test:e2e-live-blocking": "node scripts/test-e2e-live-blocking.mjs",
    "test:e2e-live-mix-blocking": "node scripts/test-e2e-live-mix-blocking.mjs",
    "test:e2e-live-deny-tools": "node scripts/test-e2e-live-deny-tools.mjs",
    "test:e2e-live-tools": "node scripts/test-e2e-live-tools.mjs",
    "test:e2e-live-extensions": "node scripts/test-e2e-live-extensions.mjs",
    "test:e2e-live-stop-after-turn": "node scripts/test-e2e-live-stop-after-turn.mjs",
    "test:e2e-live-mixed-batch": "node scripts/test-e2e-live-mixed-batch.mjs",
    "test:live-herdr-mux": "node scripts/test-live-herdr-mux.mjs",
    "test:live-herdr-pi": "node scripts/test-live-herdr-pi.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.79.0",
    "@earendil-works/pi-coding-agent": ">=0.79.0",
    "@earendil-works/pi-tui": ">=0.79.0",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@earendil-works/pi-coding-agent": "^0.79.10",
    "@earendil-works/pi-tui": "^0.79.10",
    "@types/node": "^25.9.1",
    "typebox": "^1.1.33",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "knip": {
    "ignoreBinaries": [
      "cmux",
      "ghostty",
      "herdr",
      "pkill",
      "tmux",
      "where.exe",
      "wezterm",
      "zellij"
    ]
  },
  "trustedDependencies": [
    "koffi",
    "protobufjs"
  ]
}
